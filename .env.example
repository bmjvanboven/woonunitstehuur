# ─────────────────────────────────────────────────────────────
# Woonunitstehuur — environment variables (EXAMPLE)
# Copy to `.env` for local dev and fill in real values.
# Real values live in Vercel env vars (Production/Preview/Development),
# NEVER in git. Pull them locally with: vercel env pull
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Neon or Vercel Postgres).
# Neon: copy the "pooled" connection string from the dashboard.
DATABASE_URI=postgres://user:password@host/dbname?sslmode=require

# Payload secret — long random string used to sign tokens.
# Generate a fresh one per environment, e.g.:  openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# Public site URL (admin, CORS, sitemaps). Local dev:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# (later) Vercel Blob token for media uploads, if/when we add file storage.
# BLOB_READ_WRITE_TOKEN=
